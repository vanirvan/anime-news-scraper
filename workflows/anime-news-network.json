    {
      "parameters": {
        "language": "javascript",
        "jsCode": "const extracted = $input.all()[0].json;\nconst rssData = $('Split In Batches').first().json;\n\nlet cleanTitle = extracted.title || \"\";\ncleanTitle = cleanTitle.replace(/^News\\n/, '').replace(/\\n/g, ' ').trim();\n\nlet imageUrl = extracted.image || \"\";\nif (imageUrl.startsWith('/')) {\n    imageUrl = 'https://www.animenewsnetwork.com' + imageUrl;\n}\n\nlet publishedAt = \"\";\nif (rssData.pubDate) {\n    const dateObj = new Date(rssData.pubDate);\n    if (!isNaN(dateObj.getTime())) {\n        publishedAt = dateObj.toISOString(); \n    } else {\n        publishedAt = rssData.pubDate;\n    }\n}\n\nreturn [{\n  json: {\n    title: cleanTitle,\n    url: rssData.link,\n    content: extracted.content,\n    image_url: imageUrl,\n    published_at: publishedAt,\n    source: \"Anime News Network\",\n    status: \"new\"\n  }\n}];"
      },
