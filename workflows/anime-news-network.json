    {
      "parameters": {
        "language": "javascript",
        "jsCode": "return $input.all().map((item, index) => {\n  // 1. Mengambil naskah AI langsung dari node sebelumnya (Basic LLM Chain)\n  const aiScript = item.json.text; \n  \n  // 2. Mengambil data artikel dari node Postgres berdasarkan index iterasi saat ini\n  const article = $('Postgres (Insert Article)').all()[index].json; \n\n  // Slugify judul agar aman digunakan sebagai nama file\n  const sanitizedTitle = article.title\n    .toLowerCase()\n    .replace(/[^a-z0-9\\s-]/g, '') // Hanya alfanumerik, spasi, dash\n    .trim()\n    .replace(/\\s+/g, '-')         // Spasi jadi dash\n    .replace(/-+/g, '-')          // Satukan dash ganda\n    .substring(0, 50);\n\n  // Mengambil prefix tanggal & waktu (YYYY-MM-DD-HHmm) dalam zona waktu Asia/Jakarta (+7)\n  let datePrefix = \"\";\n\n  if (article.published_at) {\n    const dateObj = new Date(article.published_at);\n    if (!isNaN(dateObj.getTime())) {\n      const formatted = new Intl.DateTimeFormat('sv-SE', {\n        timeZone: 'Asia/Jakarta',\n        year: 'numeric',\n        month: '2-digit',\n        day: '2-digit',\n        hour: '2-digit',\n        minute: '2-digit',\n        hour12: false\n      }).format(dateObj); // sv-SE outputs: \"YYYY-MM-DD HH:mm\"\n      \n      datePrefix = formatted.replace(' ', '-').replace(':', ''); // Menjadi: \"YYYY-MM-DD-HHmm\"\n    }\n  }\n  \n  if (!datePrefix) {\n    const formattedNow = new Intl.DateTimeFormat('sv-SE', {\n      timeZone: 'Asia/Jakarta',\n      year: 'numeric',\n      month: '2-digit',\n      day: '2-digit',\n      hour: '2-digit',\n      minute: '2-digit',\n      hour12: false\n    }).format(new Date());\n    \n    datePrefix = formattedNow.replace(' ', '-').replace(':', '');\n  }\n\n  // Nama file menjadi: YYYY-MM-DD-HHmm-judul.md\n  const filename = `${datePrefix}-${sanitizedTitle || 'article'}.md`;\n\n  // Template Markdown\n  const markdownContent = `===\ntitle: ${article.title}\nthumbnail: ${article.url},${article.image_url}\nsource: ${article.source}\n===\n\n![thumbnail](${article.image_url})\n\n# ${article.title}\n\n## 📝 Naskah Konten Kreator (AI)\n${aiScript}\n\n---\n\n## 📰 Berita Asli\n${article.content}\n`;\n\n  return {\n    json: {\n      filename: filename,\n      markdownContent: markdownContent\n    }\n  };\n});\n"
      },
